### Album 04 — غوڵام عەلی ڕۆمی — create
# @name create_pub_album_04
POST {{baseUrl}}/api/v1/sound-tracks
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_ALBUM_04

--KHI_CREATE_PUB_ALBUM_04
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "soundType": "گۆرانیی کوردی",
  "trackState": "MULTI",
  "albumOfMemories": false,
  "ckbCoverUrl": "{{pub_album_04_image_05}}",
  "kmrCoverUrl": "{{pub_album_04_image_05}}",
  "hoverCoverUrl": "{{pub_album_04_image_06}}",
  "newTopic": {
    "nameCkb": "گۆرانیی کوردی",
    "nameKmr": "Stranên Kurdî"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "غوڵام عەلی ڕۆمی",
    "description": "لە ساڵی ١٩٣١ لە شاری سنە لە بنەماڵەیەكی دەنگخۆش لە دایك بووە. باوكی، مەقامات و ڕەدیفەكانی مۆسیقای ئێرانی باش زانیوە و یەكێك لە هاوڕێ نزیكەكانی سەیید عەلی ئەسغەری كوردستانی بووە.\nڕۆمی، لە خزمەتی گەورە مامۆستایانی وەكو (مەحموود كەریمی و غوڵام حسێن بەنان) مەقاماتی ئێران فێر دەبێ و دەڕواتە نێو بەرنامەكانی ڕادیۆی تاران، كە تەنیا لە تاران دەبیسترا. ڕۆمی، شیعری شاعیرانی بەناوبانگی ئەو سەردەمەی ئێرانی، وەكو (دكتۆر نەییری سینا، نەواب سەفا و موعینی كرماشانی) لە گۆرانییەكانیدا بەكارهێناوە.\nغوڵام ڕۆمی، لەگەڵ هەر گۆرانییەكی فارسیدا كە لە ڕادیۆی تاران دەیخوێند، گۆرانییەكی فۆلكلۆری كوردیشی گوتووە."
  },
  "kmrContent": {
    "title": "Xulam Elî Romî",
    "description": "Xulam Elî Romî, di sala 1931’ê de li bajarê Sine ji malbatek dengxweş ji dayik bûye. Bavê wî, meqamên Îraniyan baş zanîbû û ji hevalên nêzîk yên Seyid ‘Elî Esxer Kurdistanî bûye.\nRomî, li jêr destê mamostayên mîna (Mehmûd Kerîmî û Xulam Hisên Benan) fêrî meqamên îranî dibe, herweha helbestên helbestvanên bi navûdeng yên wê serdemê, weku (Dr. Neyîrî Sîna, Newabî Sefa û Mu’înî Kirmaşanî) kirine stiran.\nXulam Elî Romî, heta vê berwarê -2021- li jiyanê maye û li Tehranê dimîne."
  },
  "locations": [
    "کوردستان"
  ],
  "reader": "غوڵام عەلی ڕۆمی",
  "directors": [],
  "terms": "ئەرشیفی دەنگ",
  "thisProjectOfInstitute": true,
  "tags": {
