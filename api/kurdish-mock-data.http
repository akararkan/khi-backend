### Album 01 — خەلیل سدیقی — create
# @name create_pub_album_01
POST {{baseUrl}}/api/v1/sound-tracks
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_ALBUM_01

--KHI_CREATE_PUB_ALBUM_01
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "soundType": "گۆرانیی کوردی",
  "trackState": "MULTI",
  "albumOfMemories": false,
  "ckbCoverUrl": "{{pub_album_01_image_03}}",
  "kmrCoverUrl": "{{pub_album_01_image_03}}",
  "hoverCoverUrl": "{{pub_album_01_image_04}}",
  "newTopic": {
    "nameCkb": "گۆرانیی کوردی",
    "nameKmr": "Stranên Kurdî"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "خەلیل سدیقی",
    "description": "ساڵی ١٩٣٠ لە بنەماڵەیكی ناسراوی شاری مەهاباد لەدایك بووە. زۆربەی كاتی منداڵی، لە گوندەكەی خۆیان \"تازەقەڵای نزیكی نەغەدە\"، گوزەراندووە.\nخەلیل ساڵانی ١٩٥٣-١٩٦٣ لە ڕادیۆی مەهاباد گۆرانی گوتووە، دەنگی ئەم ڕادیۆیە، تەنها لە شاری مەهاباد و ئاواییەكانی دەوروبەری بیستراوە، بەرهەمەكانیش ڕاستەوخۆ بڵاوكراونەتەوە و تۆمارنەبوون. لەم ڕادیۆیەدا، پەیوەندی لەگەڵ چەند هونەرمەندێكدا هەبووە، وەك: سەید ڕەحیم قوڕەیشی، برایم ئەفخەمی و بیووك خانباغی.\nلە ٤/٢/١٩٧٠ سدیقی لە نەخۆشخانەی شێروخورشیدی شاری مەهاباد ماڵئاوایی یەكجاری كردووە و لە گۆڕستانی بوداغ سوڵتانی ئەو شارە نێژراوە."
  },
  "kmrContent": {
    "title": "Xelîl Sidîqî",
    "description": "Di sala 1930'î de, ji malbateke naskirî li bajarê Mehabadê ji dayik bûye û demên zaroktiya xwe li gundê xwe ''Tazeqela yê nêzîkî Nexede'' derbas kiriye.\nXelîl, di salên 1953- 1963'yan de, li radyoya Mehabadê stiran gotine, dengê vê radyoyê tenê li Mehabadê û derdora wê dihate weşandin û berhemên wê nedihatin tomar kirin bi tenê zindî dihatine belav kirin. Di vê radyoyê de, peywendiya wî bi çend hunermendan re hebûye, wek: Seyid Rehîm Qureyşî, Birayim Efxemî û Byûk Xanbaxî.\nDi 4/2/1970'î de, li nexweşxaneya Şêruxurşîdî ya bajarê Mehabadê koça dawî kiriye û li goristana Budax Sultanî ya bajêr termê wî hatiye veşartin."
  },
  "locations": [
    "کوردستان"
  ],
  "reader": "خەلیل سدیقی",
  "directors": [],
  "terms": "ئەرشیفی دەنگ",
  "thisProjectOfInstitute": true,
  "tags": {
    "ckb": [
      "گۆرانی",
      "مۆسیقای کوردی",
      "خەلیل سدیقی"
    ],
    "kmr": [
      "stran",
      "muzîka kurdî",
      "Xelîl Sidîqî"
    ]
  },
  "keywords": {
    "ckb": [
      "ئەرشیفی دەنگ",
      "کوردستان"
    ],
    "kmr": [
      "arşîva deng",
      "Kurdistan"
    ]
  },
  "albumName": "خەلیل سدیقی",
  "totalTracks": 3,
  "files": [
    {
      "fileUrl": "{{pub_album_01_track_001}}",
      "fileType": "MP3",
      "title": "Harme",
      "sizeBytes": 13824234,
      "durationSeconds": 0,
      "genre": "Kurdish",
      "sortOrder": 0,
      "brochures": [
        {
          "imageUrl": "{{pub_album_01_image_01}}",
          "caption": "01"
        },
        {
          "imageUrl": "{{pub_album_01_image_02}}",
          "caption": "02"
        }
      ]
    },
    {
      "fileUrl": "{{pub_album_01_track_002}}",
      "fileType": "MP3",
      "title": "Barhalbena",
      "sizeBytes": 11722944,
      "durationSeconds": 0,
      "genre": "Kurdish",
      "sortOrder": 1,
      "brochures": []
    },
    {
      "fileUrl": "{{pub_album_01_track_003}}",
      "fileType": "MP3",
      "title": "Lankole.2",
      "sizeBytes": 6841181,
      "durationSeconds": 0,
      "genre": "Kurdish",
      "sortOrder": 2,
      "brochures": []
    }
  ],
  "attachments": []
}
--KHI_CREATE_PUB_ALBUM_01--

> {%
  client.assert(response.status === 201, "create_pub_album_01 create failed");
  client.global.set("pub_album_01_id", response.body.data.id);
%}

### Album 01 — خەلیل سدیقی — verify
# @name verify_create_pub_album_01
GET {{baseUrl}}/api/v1/sound-tracks/{{pub_album_01_id}}
Authorization: Bearer {{auth_token}}

> {%
  client.assert(response.status === 200, "create_pub_album_01 verification failed");
  client.assert(response.body.data.trackState === "MULTI", "Album 01 state mismatch");
  client.assert(response.body.data.files.length === 3, "Album 01 track count mismatch");
%}

