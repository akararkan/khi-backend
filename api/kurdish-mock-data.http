### Album 03 — تاهیر تۆفیق — verify
# @name verify_create_pub_album_03
GET {{baseUrl}}/api/v1/sound-tracks/{{pub_album_03_id}}
Authorization: Bearer {{auth_token}}

> {%
  client.assert(response.status === 200, "create_pub_album_03 verification failed");
  client.assert(response.body.data.trackState === "MULTI", "Album 03 state mismatch");
  client.assert(response.body.data.files.length === 73, "Album 03 track count mismatch");
%}

