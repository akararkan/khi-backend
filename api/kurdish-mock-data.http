### Album 06 — حەمە قوتوو — create
# @name create_pub_album_06
POST {{baseUrl}}/api/v1/sound-tracks
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_ALBUM_06

--KHI_CREATE_PUB_ALBUM_06
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "soundType": "گۆرانیی کوردی",
  "trackState": "MULTI",
  "albumOfMemories": false,
  "ckbCoverUrl": "{{pub_album_06_image_04}}",
  "kmrCoverUrl": "{{pub_album_06_image_04}}",
  "hoverCoverUrl": "{{pub_album_06_image_07}}",
  "newTopic": {
    "nameCkb": "گۆرانیی کوردی",
    "nameKmr": "Stranên Kurdî"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "حەمە قوتوو",
    "description": "ساڵی ١٩٣٩ لە شاری هەڵەبجە لە دایك بووە. بەهۆی ئەوەی كە لەمنداڵییەوە بەشێوەیەكی پۆشتە جوان دەركەوتووە، بە (حەمە قوتوو) ناسراوە.\nساڵی ١٩٥٤ چووتە ئێستگەی بەغدا و لە تاقیكردنەوەی دەنگیدا سەركەوتووبووە و شەش گۆرانی بەناوەكانی (بارانە، گوڵاڵە سوورە، خانم خانم، لەكۆڵانی تەنگەبەر، مەگری مەگری و هەی بەلار و بەلار) تۆمار كردووە. هەر لەم كاتانەدا، بە هونەرمەندان (عەلی مەردان، عیسا بەورایی و حەسەن جەزراوی) ئاشنابووە.\nژمارەیەك گۆرانی بۆ تەلەڤزیۆنی كەركووك تۆمار كردووە و لەگەڵ تیپی مۆسیقای سلێمانی و مەولەوی و شنروێدا بەرهەمی هەیە و لە شارەكانی سلێمانی، هەولێر و دهۆك بەشداری چەندین ڤێستیڤاڵ و ئاهەنگێكی كردووە و ئەندامی سەندیكای هونەرمەندانی كوردستان بووە."
  },
  "kmrContent": {
    "title": "Heme Qutû",
    "description": "Di sala 1939'an li bajarê Helebçe ji dayik bûye. Ji ber ku ji zaroktiya xwe de bi şêweyekî xweşik cil li xwe dikirin, navê wî bi (Heme Qutû) derdikeve.\nDi sala 1954'an, çûye êzgeha Bexdayê û di ezmûna deng de biser dikeve û şeş sitranên bi navên (Baran e, Gulale Sûr e, Xanim Xanim, Le Kolanî Tengeber, Megrî Megrî û Hey Belar û Belar) tomar kiriye. Her di wê demê de nasînê bi hunermendan (E'lî Merdan, Î'sa Berwarî û Hesenê Cizîrî) re dike.\nHejmareke sitran ji bo televizyona Kerkûkê tomar kiriye û ligel (Tîpî Mosîqay Silêmanî- Mewlewî û Şinrwê) berhem tomar kiriye û li Silêmaniyê, Hewlêr û Dihokê beşdarî li çendîn festîval û ahengan kiriye û endamê sendîkaya hunermendanê Kurdistanê bûye."
  },
  "locations": [
    "کوردستان"
  ],
  "reader": "حەمە قوتوو",
  "directors": [],
  "terms": "ئەرشیفی دەنگ",
  "thisProjectOfInstitute": true,
  "tags": {
    "ckb": [
      "گۆرانی",
      "مۆسیقای کوردی",
      "حەمە قوتوو"
    ],
    "kmr": [
      "stran",
      "muzîka kurdî",
      "Heme Qutû"
    ]
  },
  "keywords": {
    "ckb": [
      "ئەرشیفی دەنگ",
      "کوردستان"
    ],
    "kmr": [
      "arşîva deng",
      "Kurdistan"
    ]
  },
  "albumName": "حەمە قوتوو",
  "totalTracks": 3,
  "files": [
    {
      "fileUrl": "{{pub_album_06_track_001}}",
      "fileType": "MP3",
      "title": "la kolany tangm",
      "sizeBytes": 10078100,
      "durationSeconds": 0,
      "genre": "Kurdish",
      "sortOrder": 0,
      "brochures": [
