### Book 01 — لاپەڕەیەك لە بنەماكانی موزیكی كوردیی — create
# @name create_pub_book_01
POST {{baseUrl}}/api/v1/writings
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_BOOK_01

--KHI_CREATE_PUB_BOOK_01
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbCoverUrl": "{{pub_book_01_ckb_cover}}",
  "kmrCoverUrl": "{{pub_book_01_kmr_cover}}",
  "hoverCoverUrl": "{{pub_book_01_hover_cover}}",
  "ckbContent": {
    "title": "لاپەڕەیەك لە بنەماكانی موزیكی كوردیی",
    "description": "<p>لەم توێژینەوەیەدا وەڵامی چەند پرسیارێك دەدرێتەوە، لەوانە: ئایا چەند پۆل گۆرانی كوردیی هەیە و چۆن ئەم گۆرانییانە پۆلێن بكرێن؟ جۆرەكانی میانە (Interval) لە گۆرانی فۆلكلۆری كوردییدا چین و گرنگەكانیان كامانەن؟ ئایا لە گۆرانی كوردییدا چەند جۆر چواریلە (Tetrachord) هەن و ناویان چییە؟</p>",
    "writer": "ع. ج. سەگرمە",
    "fileUrl": "{{pub_book_01_pdf}}",
    "fileFormat": "PDF",
    "fileSizeBytes": 578317,
    "pageCount": 12,
    "genre": "کتێبی کەلەپووری"
  },
  "kmrContent": {
    "title": "Lapereyek le Binemakanî Muzîkî Kurdî",
    "description": "<p>Ev lêkolîn bersiva çend pirsan dide, ji wan: Çend kategoriyên stiranên kurdî hene û ev stiran çawa têne dabeşkirin? Di stranên gelêrî yên kurdî de cureyên navberê çi ne? Di stirana kurdî de çend cureyên tetrakordan hene û navên wan çi ne?</p>",
    "writer": "Ebdulla Cemal Segirme",
    "fileUrl": "{{pub_book_01_pdf}}",
    "fileFormat": "PDF",
    "fileSizeBytes": 578317,
    "pageCount": 12,
    "genre": "Pirtûka kelepûrî"
  },
  "newTopic": {
    "nameCkb": "کتێب",
    "nameKmr": "Pirtûk"
  },
  "bookGenres": [
    "ARTS",
    "EDUCATIONAL"
  ],
  "publishedByInstitute": true,
  "tags": {
    "ckb": [
      "کتێب",
      "کەلەپووری کورد"
    ],
    "kmr": [
      "pirtûk",
      "kelepûra Kurdî"
    ]
  },
  "keywords": {
    "ckb": [
      "لاپەڕەیەك لە بنەماكانی موزیكی كوردیی",
      "کوردستان"
    ],
    "kmr": [
      "Lapereyek le Binemakanî Muzîkî Kurdî",
      "Kurdistan"
    ]
  },
  "seriesOrder": 1
}
--KHI_CREATE_PUB_BOOK_01--

