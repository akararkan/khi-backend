### KHI Kurdish Mock Data — 1 Film + 1 Video Clip
#
# ─── VIDEO FILE UPLOAD — TWO APPROACHES ──────────────────────────────────────
#
# APPROACH A — Pre-upload, then pass the returned URL in the JSON (unchanged)
#   1. POST /api/v1/media/upload       → returns { data: { fileUrl: "…" } }
#   2. Set "sourceUrl" / "url" in the JSON "data" part of the create request.
#   Use when: file is already hosted, or you want to reuse a URL across records.
#
# APPROACH B — Direct inline upload in ONE request (new — recommended for clips)
#   All files are sent as named multipart parts in the same POST/PUT call:
#     ckbCoverImage  → cover image for CKB dialect
#     kmrCoverImage  → cover image for KMR dialect
#     hoverImage     → hover/thumbnail cover image
#     videoFiles     → list of video files (repeat this part name for each file)
#                      FILM:       videoFiles[0]   = the single film file
#                      VIDEO_CLIP: videoFiles[i]   maps to videoClipItems[i] by index
#   Uploaded files override any URL already present in the JSON.
#   No "url" / "sourceUrl" field needed when supplying the file directly.
#
# The examples below use APPROACH B (direct inline upload).
# A separate APPROACH A block is kept at the bottom for reference.
#
# ─── HOW TO RUN ───────────────────────────────────────────────────────────────
# client.global.set(...) only makes a variable available to LATER requests in
# the SAME session/environment, run AFTER the request that sets it. Run every
# request top-to-bottom on the first pass. After that you can re-run individual
# requests as long as the globals they depend on are still set.
#
# CREDENTIALS: do not hardcode real username/password in this file.
# Create a private, gitignored environment file (see bottom of this file for
# an example) and reference @username / @password from there. Rotate any
# credential that has ever been pasted in plain text — treat it as compromised.
# ------------------------------------------------------------------

@baseUrl = https://blissful-spontaneity-production.up.railway.app

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "akar",
  "password": "11111111"
}

> {%
    client.assert(response.status === 200, "Login failed: HTTP " + response.status + " " + JSON.stringify(response.body));
    client.assert(response.body.token, "Login succeeded but no token in response body");
    client.global.set("auth_token", response.body.token);
%}

###############################################################################
# FILM 01 — پێکەوەژیانی ئاینەکان   (APPROACH B — direct inline upload)
#
# Parts sent in a single POST:
#   ckbCoverImage  → poster image (CKB cover)
#   kmrCoverImage  → poster image (KMR cover)
#   videoFiles     → the film file  (maps to sourceUrl for FILM type)
#   data           → JSON metadata  (no sourceUrl needed)
###############################################################################

### Film 01 — create
# @name create_pub_film_01
POST {{baseUrl}}/api/v1/videos
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_FILM_01

--KHI_CREATE_PUB_FILM_01
Content-Disposition: form-data; name="ckbCoverImage"; filename="Poster_pekawa zhyan.jpg"
Content-Type: image/jpeg

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Films/پێکەوەژیانی ئاینەکان/Poster_pekawa zhyan.jpg
--KHI_CREATE_PUB_FILM_01
Content-Disposition: form-data; name="kmrCoverImage"; filename="Poster_pekawa zhyan.jpg"
Content-Type: image/jpeg

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Films/پێکەوەژیانی ئاینەکان/Poster_pekawa zhyan.jpg
--KHI_CREATE_PUB_FILM_01
Content-Disposition: form-data; name="videoFiles"; filename="Pekawa Zhiany Ainakan.mp4"
Content-Type: video/mp4

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Films/پێکەوەژیانی ئاینەکان/Pekawa Zhiany Ainakan.mp4
--KHI_CREATE_PUB_FILM_01
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "videoType": "FILM",
  "albumOfMemories": false,
  "newTopic": {
    "nameCkb": "فیلمی بەڵگەنامەیی",
    "nameKmr": "Belgefîlm"
  },
  "contentLanguages": ["CKB", "KMR"],
  "ckbContent": {
    "title": "فیلمی پێکەوەژیان",
    "description": "<p>فیلمی بۆ پێکەوەژیان</p>",
    "location": "کوردستان",
    "producer": "ستودیو"
  },
  "kmrContent": {
    "title": "Fîlmê Pêkvejiyan",
    "description": "<p>Documentary film</p>",
    "location": "Kurdistan",
    "producer": "Studio"
  },
  "fileFormat": "mp4",
  "fileSizeMb": 500.00,
  "tagsCkb": ["فیلم"],
  "tagsKmr": ["fîlm"]
}
--KHI_CREATE_PUB_FILM_01--

> {%
    client.assert(response.status === 201, "create_pub_film_01 failed: HTTP " + response.status + " " + JSON.stringify(response.body));
    client.assert(response.body.id, "create_pub_film_01 succeeded but no id in response");
    client.global.set("pub_film_01_id", response.body.id);
%}

### Film 01 — verify
# @name verify_create_pub_film_01
GET {{baseUrl}}/api/v1/videos/{{pub_film_01_id}}
Authorization: Bearer {{auth_token}}

> {%
    client.assert(response.status === 200, "Film 01 verification failed: HTTP " + response.status + " " + JSON.stringify(response.body));
%}

###############################################################################
# VIDEO CLIP 01 — گروپی کچانی گلاریس   (APPROACH B — direct inline upload)
#
# Parts sent in a single POST (repeat "videoFiles" once per clip, in order):
#   ckbCoverImage  → collection cover image
#   videoFiles     → clip 1 of 3  (maps to videoClipItems[0])
#   videoFiles     → clip 2 of 3  (maps to videoClipItems[1])
#   videoFiles     → clip 3 of 3  (maps to videoClipItems[2])
#   data           → JSON metadata; videoClipItems have no "url" field —
#                    the uploaded files supply them automatically.
#
# Index rule: videoFiles[i] → videoClipItems[i] (zero-based, by position).
# If you skip a clip's file (null slot), that clip must have a "url" /
# "externalUrl" / "embedUrl" in the JSON instead.
###############################################################################

### Video 01 — create
# @name create_pub_video_01
POST {{baseUrl}}/api/v1/videos
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_VIDEO_01

--KHI_CREATE_PUB_VIDEO_01
Content-Disposition: form-data; name="ckbCoverImage"; filename="حــەریــرە...jpg"
Content-Type: image/jpeg

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Videos/گــروپــی کچانی گلاریس/حــەریــرە/حــەریــرە...jpg
--KHI_CREATE_PUB_VIDEO_01
Content-Disposition: form-data; name="videoFiles"; filename="حــەریــرە.mp4"
Content-Type: video/mp4

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Videos/گــروپــی کچانی گلاریس/حــەریــرە/حــەریــرە.mp4
--KHI_CREATE_PUB_VIDEO_01
Content-Disposition: form-data; name="videoFiles"; filename="دڵم تەنگ و ناشادە.mp4"
Content-Type: video/mp4

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Videos/گــروپــی کچانی گلاریس/دڵم تەنگ و ناشادە/دڵم تەنگ و ناشادە.mp4
--KHI_CREATE_PUB_VIDEO_01
Content-Disposition: form-data; name="videoFiles"; filename="کرماشان.mp4"
Content-Type: video/mp4

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Videos/گــروپــی کچانی گلاریس/کرماشان/کرماشان.mp4
--KHI_CREATE_PUB_VIDEO_01
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "videoType": "VIDEO_CLIP",
  "albumOfMemories": false,
  "newTopic": {
    "nameCkb": "گۆرانیی ڤیدیۆیی",
    "nameKmr": "Klîpên Stranan"
  },
  "contentLanguages": ["CKB", "KMR"],
  "ckbContent": {
    "title": "گروپی کچانی گلاریس",
    "description": "<p>کلیپە ڤیدیۆیی</p>",
    "location": "کوردستان",
    "producer": "ستودیو"
  },
  "kmrContent": {
    "title": "Girûpa Keçên Glarîs",
    "description": "<p>Video clips</p>",
    "location": "Kurdistan",
    "producer": "Studio"
  },
  "tagsCkb": ["ڤیدیۆ"],
  "tagsKmr": ["vîdyo"],
  "videoClipItems": [
    {
      "clipNumber": 1,
      "fileFormat": "mp4",
      "fileSizeMb": 200.00,
      "titleCkb": "حەریرە",
      "titleKmr": "Herîre"
    },
    {
      "clipNumber": 2,
      "fileFormat": "mp4",
      "fileSizeMb": 250.00,
      "titleCkb": "دڵم تەنگ",
      "titleKmr": "Dilim Teng"
    },
    {
      "clipNumber": 3,
      "fileFormat": "mp4",
      "fileSizeMb": 280.00,
      "titleCkb": "کرماشان",
      "titleKmr": "Kirmaşan"
    }
  ]
}
--KHI_CREATE_PUB_VIDEO_01--

> {%
    client.assert(response.status === 201, "create_pub_video_01 failed: HTTP " + response.status + " " + JSON.stringify(response.body));
    client.assert(response.body.id, "create_pub_video_01 succeeded but no id in response");
    client.global.set("pub_video_01_id", response.body.id);
%}

### Video 01 — verify
# @name verify_create_pub_video_01
GET {{baseUrl}}/api/v1/videos/{{pub_video_01_id}}
Authorization: Bearer {{auth_token}}

> {%
    client.assert(response.status === 200, "Video 01 verification failed: HTTP " + response.status + " " + JSON.stringify(response.body));
%}

###############################################################################
# VIDEO CLIP 01 — UPDATE (replace clip 2 file, keep clip 1 & 3 unchanged)
#
# On update, pass clip items WITH their persisted IDs.
# videoFiles[i] still maps to videoClipItems[i] by index.
# Omit videoFiles entirely (or send null for an index) to keep the
# existing clip source; only supply a file when you want to replace it.
###############################################################################

### Video 01 — update clip 2 file
# @name update_pub_video_01_clip2
PUT {{baseUrl}}/api/v1/videos/{{pub_video_01_id}}
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_UPDATE_PUB_VIDEO_01

--KHI_UPDATE_PUB_VIDEO_01
Content-Disposition: form-data; name="videoFiles"; filename="new_clip2.mp4"
Content-Type: video/mp4

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Videos/گــروپــی کچانی گلاریس/new_clip2.mp4
--KHI_UPDATE_PUB_VIDEO_01
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "videoType": "VIDEO_CLIP",
  "videoClipItems": [
    {
      "id": 1,
      "clipNumber": 1,
      "titleCkb": "حەریرە",
      "titleKmr": "Herîre"
    },
    {
      "id": 2,
      "clipNumber": 2,
      "titleCkb": "دڵم تەنگ — نوێکرایەوە",
      "titleKmr": "Dilim Teng — Updated"
    },
    {
      "id": 3,
      "clipNumber": 3,
      "titleCkb": "کرماشان",
      "titleKmr": "Kirmaşan"
    }
  ]
}
--KHI_UPDATE_PUB_VIDEO_01--

> {%
    client.assert(response.status === 200, "update_pub_video_01_clip2 failed: HTTP " + response.status + " " + JSON.stringify(response.body));
%}

###############################################################################
# APPROACH A — Pre-upload reference (still fully supported)
#
# Use this when you want to host files through the media endpoint first
# and then reference the returned URL across multiple records, or when
# the file is already hosted on S3/CDN.
#
# FILM — pre-upload then URL reference
###############################################################################

### Film cover pre-upload (APPROACH A)
# @name upload_film_cover_a
POST {{baseUrl}}/api/v1/media/upload
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_UPLOAD_FILM_COVER_A

--KHI_UPLOAD_FILM_COVER_A
Content-Disposition: form-data; name="file"; filename="cover.jpg"
Content-Type: image/jpeg

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Films/پێکەوەژیانی ئاینەکان/Poster_pekawa zhyan.jpg
--KHI_UPLOAD_FILM_COVER_A
Content-Disposition: form-data; name="type"

image
--KHI_UPLOAD_FILM_COVER_A--

> {%
    client.assert(response.status === 200, "film cover upload failed: HTTP " + response.status);
    client.global.set("film_cover_url_a", response.body.data.fileUrl);
%}

### Film video pre-upload (APPROACH A)
# @name upload_film_video_a
POST {{baseUrl}}/api/v1/media/upload
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_UPLOAD_FILM_VIDEO_A

--KHI_UPLOAD_FILM_VIDEO_A
Content-Disposition: form-data; name="file"; filename="Pekawa Zhiany Ainakan.mp4"
Content-Type: video/mp4

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Films/پێکەوەژیانی ئاینەکان/Pekawa Zhiany Ainakan.mp4
--KHI_UPLOAD_FILM_VIDEO_A
Content-Disposition: form-data; name="type"

video
--KHI_UPLOAD_FILM_VIDEO_A--

> {%
    client.assert(response.status === 200, "film video upload failed: HTTP " + response.status);
    client.global.set("film_video_url_a", response.body.data.fileUrl);
%}

### Film 02 — create (APPROACH A — URL reference)
# @name create_film_02_url
POST {{baseUrl}}/api/v1/videos
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_FILM_02_URL

--KHI_CREATE_FILM_02_URL
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "ckbCoverUrl": "{{film_cover_url_a}}",
  "kmrCoverUrl": "{{film_cover_url_a}}",
  "videoType": "FILM",
  "albumOfMemories": false,
  "contentLanguages": ["CKB", "KMR"],
  "ckbContent": {
    "title": "فیلمی پێکەوەژیان ٢",
    "description": "<p>فیلمی بەڵگەنامەیی</p>",
    "location": "کوردستان"
  },
  "kmrContent": {
    "title": "Fîlmê Pêkvejiyan 2",
    "description": "<p>Documentary film</p>",
    "location": "Kurdistan"
  },
  "sourceUrl": "{{film_video_url_a}}",
  "fileFormat": "mp4",
  "fileSizeMb": 500.00,
  "tagsCkb": ["فیلم"],
  "tagsKmr": ["fîlm"]
}
--KHI_CREATE_FILM_02_URL--

> {%
    client.assert(response.status === 201, "create_film_02_url failed: HTTP " + response.status + " " + JSON.stringify(response.body));
    client.global.set("pub_film_02_id", response.body.id);
%}

###############################################################################
# ENVIRONMENT FILE (create this separately — do NOT put real creds in this
# .http file, and do NOT commit the environment file to git):
#
# http-client.env.json (add to .gitignore!)
# {
#   "local": {
#     "username": "your-admin-username",
#     "password": "your-real-password"
#   }
# }
#
# In VS Code REST Client: select the "local" environment before running.
# In IntelliJ HTTP Client: pick the environment from the dropdown.
###############################################################################
