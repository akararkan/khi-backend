### KHI real content import
### IntelliJ HTTP Client / VS Code REST Client compatible.
### Source: the local content folders under /Users/khi/Downloads/Site.
### Run the requests from top to bottom. Media uploads must finish before record creation.
### Every media file is uploaded before its record is created.

@baseUrl = https://blissful-spontaneity-production.up.railway.app
@username = akar
@password = 11111111

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
  client.assert(response.status === 200, "Login failed");
  client.global.set("auth_token", response.body.token);
%}

###############################################################################
# PUBLISHMENTS — REAL FOLDER DATA
###############################################################################
# Run Login once, then run each record's uploads, create, and verify requests in order.
# Do not use parallel Run All: large audio/video uploads must complete before create.
# Deploy the streaming-upload backend change before sending the large film/video files.
# If Railway returns HTTP 502 "upstream error", wait for the service to recover and rerun only that upload.
# Ali Mardan and Tahir Tofiq use their `All` track folders; duplicate CD copies are skipped.

###############################################################################
# ALBUMS — 8 MULTI-SOUND RECORDS
###############################################################################

###############################################################################
# ALBUM 01 — خەلیل سدیقی (3 unique tracks)
###############################################################################

### Album 01 image 1/4
# @name upload_pub_album_01_image_01
POST {{baseUrl}}/api/v1/media/upload
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_UPLOAD_PUB_ALBUM_01_IMAGE_01

--KHI_UPLOAD_PUB_ALBUM_01_IMAGE_01
Content-Disposition: form-data; name="file"; filename="01.jpg"
Content-Type: image/jpeg

< /Users/khi/Downloads/Site/بابەتەکانی ئەپڵۆدکردن/Publish/Albums/١٣- خەلیل سدیقی/بروشور/01.jpg
--KHI_UPLOAD_PUB_ALBUM_01_IMAGE_01
Content-Disposition: form-data; name="type"

image
--KHI_UPLOAD_PUB_ALBUM_01_IMAGE_01--

> {%
  client.assert(response.status === 200, "upload_pub_album_01_image_01 upload failed: HTTP " + response.status + " " + JSON.stringify(response.body));
  client.global.set("pub_album_01_image_01", response.body.data.fileUrl);
%}

