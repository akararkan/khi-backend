### Album 05 — عەلی ئەلبورزی — create
# @name create_pub_album_05
POST {{baseUrl}}/api/v1/sound-tracks
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_ALBUM_05

--KHI_CREATE_PUB_ALBUM_05
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "soundType": "گۆرانیی کوردی",
  "trackState": "MULTI",
  "albumOfMemories": false,
  "ckbCoverUrl": "{{pub_album_05_image_03}}",
  "kmrCoverUrl": "{{pub_album_05_image_03}}",
  "hoverCoverUrl": "{{pub_album_05_image_04}}",
  "newTopic": {
    "nameCkb": "گۆرانیی کوردی",
    "nameKmr": "Stranên Kurdî"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "عەلی ئەلبورزی",
    "description": "هونەرمەند عەلی ئەلبورزی، ساڵی ١٩٢٠ لە شاری كرماشان هاتووەتە دنیاوە. ساڵی ١٩٥١ چووەتە ئێزگەی تاران و وەك یەكەمین گۆرانیبێژی كورد لەگەڵ ئۆركسترای ڕادیۆی ئەو سەردەمەدا، بەستە و گۆرانییەكانی ناوچەی كرماشانی بەشێوەی كەڵهوڕی وتووە...\nعەلی ئەلبورزی، لەگەڵ خانمە گۆرانیبێژی بەناوبانگی ئێرانی ئەوسەردەمە (ملووك زەڕایی) چەندین گۆرانی كوردیی و فارسییان وتووە. (ئەلبوورزی بە زمانی كوردیی و خانمی زەڕاییش بە هۆنراوەی فارسی وەڵامی داوەتەوە).\nئەو گۆرانییانەی كە لە ئێستا لەبەردەستدایە، بەشێكی كەمی كارە هونەرییەكانی هونەرمەندە و زۆربەیان لەناوچوون.\nعەلی ئەلبورزی، ساڵی ٢٠٠٤ لە شاری تاران كۆچی دوایی كردووە و هەر لەوێش بەخاك سپێردراوە."
  },
  "kmrContent": {
    "title": "Elî Elburzî",
    "description": "Hunermend Elî Elburzî, sala 1920'ê li bajarê Kirmaşan ji dayik bûye. Sala 1951'ê çûye êzgeha Tehranê û wek yekemîn sitranbêjê Kurd li gel orkêstra ya radyoya wê serdemê, beste û sitranên navçeya Kirmaşan bi şêweyê Kelhurî gotiye.\nElî Elburzî, li gel xanima bi navûdeng a Êranî ya wê serdemê (Milûk Zerayî) çendîn sitranên Kurdî û Farisî gotiye (Elburzî bi zimanê Kurdî û Zerayî jî bi sitranên Farisî bersiva wî daye)\nEw sitranên aniha li ber destên me ne, beşekî kêm in ji karên hunerê yê vî hunermendî û mixabin piraniya sitranên wî winda bûne.\nElî Elburzî, sala 2004'ê li bajarê Tehranê koça dawî kiriye û li wir hatiye veşartin."
  },
  "locations": [
    "کوردستان"
  ],
  "reader": "عەلی ئەلبورزی",
  "directors": [],
  "terms": "ئەرشیفی دەنگ",
  "thisProjectOfInstitute": true,
  "tags": {
    "ckb": [
      "گۆرانی",
      "مۆسیقای کوردی",
      "عەلی ئەلبورزی"
    ],
    "kmr": [
      "stran",
      "muzîka kurdî",
      "Elî Elburzî"
    ]
  },
  "keywords": {
    "ckb": [
      "ئەرشیفی دەنگ",
      "کوردستان"
    ],
    "kmr": [
      "arşîva deng",
      "Kurdistan"
    ]
  },
  "albumName": "عەلی ئەلبورزی",
  "totalTracks": 7,
  "files": [
