### Film 02 — فیلمی پێکەوەژیان — create
# @name create_pub_film_02
POST {{baseUrl}}/api/v1/videos
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_FILM_02

--KHI_CREATE_PUB_FILM_02
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "ckbCoverUrl": "{{pub_film_02_cover}}",
  "kmrCoverUrl": "{{pub_film_02_cover}}",
  "videoType": "FILM",
  "albumOfMemories": false,
  "newTopic": {
    "nameCkb": "فیلمی بەڵگەنامەیی",
    "nameKmr": "Belgefîlm"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "فیلمی پێکەوەژیان",
    "description": "<p>ئەم بەڵگە فیلمە باس لە پێکەوەژیان دەکات لە کوردستان، کە سەرزەمینی ئاشتی و پێکەوەژیانە.</p><p>گوندی شانەدەر:</p><p>گوندێکی مێژووییە دەکەوێتە پاریزگای دهۆکەوە لە باشوری کوردستان. دانیشتوانەکەی پەیڕەوکاری ئاینی مەسیحین، بە ئاشتی و پێکەوەژیان دەژین لەگەڵ خەڵکی ناوچەکە و دەوروبەر.</p><p>لالش:</p><p>لالش پەرستگای ئێزدیەکانە لە کوردستان، ئێزدی یەکێکە لە ئاینە دێرینەکانی خۆرهەڵاتی ناوەڕاست.</p><p>پیرشالیار:</p><p>کورد بەگشتی مسوڵمانن، لە چەند سەدەی ڕابردوو هەردوو ڕەوتی بیری سۆفیگەری و دەروێشی سەریانهەڵداوە تا زیاتر خۆیان لە خواوەند نزیکبکەنەوە.</p><p>کەرکوک:</p><p>لە کەرکوک جگە لە هەردوو نەتەوەی کورد و عەرەب و تورکمان و مەسیحی و کاکەییەکان پەیڕەوانی ئاینی (صائبە) کە مێژووەکەی دەگەڕێتەوە بۆ سەردەمی (ئارامی)یەکان و چوارهەزار ساڵ لەمەوبەر لەلێواری فوڕاتدا ژیاون.</p><p>یارسان:</p><p>ئاینی یارسان (کاکەیی) لەئاینە دێرینەکانی کوردستانە، لایەنگرانی ئەم ئاینە بە شێوەزاری کەلهوڕی دەدوێن. ئامێری تەموورە(دووتار) لە بۆنەو مەراسیمە ئاینیەکانیاندا بە تاک یان بەکۆمەڵ دەژەنن.</p>",
    "location": "کوردستان",
    "producer": "ئنستیتیوتی کەلەپووری کورد"
  },
  "kmrContent": {
    "title": "Fîlmê Pêkvejiyan",
    "description": "<p>Ev belge film behsa  pêkvejiyanê li Kurdistanê dike, ku Kurdistan bûye cihê aştî û pêkvejiyanê li rojhilat.</p><p>Gundê Şaneder:</p><p>Gundekî dîrokî ye û dikeve parêzgeha Dihokê ya Başûrê Kurdistanê. Niştecihên wê Xiristiyan in, bi gelên herêmê û derdorê re di nava aramî û jiyana hevbeş de dijîn.</p><p>Laleş:</p><p>Laleş perestgeha Êzdiyan e li Kurdistanê ye. Êzdî yek ji kevintirîn olên Rojhilata Navîn e.</p><p>Pîr Şalyar:</p><p>Kurd bi giştî misilman in, di çend sedsalên borî de, her du tevgerên tesewufî û derwêşî derketine û mebest jê ku bêtir xwe nêzîkî Xweda bikin.</p><p>Kerkûk:</p><p>Li Kerkûkê ji bilî Kurd, Ereb, Tirkmen, Xiristiyan û Kakayî, peyrewên ola Sabî ku vedigere serdema aramî û beriya 4 hezar salan li peravên Firatê dijiyan.</p><p>Yarsan:</p><p>Ola Yarsan (Kakayî) yek ji kevintirîn olên Kurdistanê ye. Peyrewên vê olê bi şêwezarê Kelhurî diaxivin. Di merasîmên xwe yên olî de bi kom li tembûrê (Dutarê) didin.</p>",
    "location": "Kurdistan",
    "producer": "Enstîtuya Kelepûra Kurdî"
  },
  "sourceUrl": "{{pub_film_02_video}}",
  "fileFormat": "mp4",
  "fileSizeMb": 327.39,
  "tagsCkb": [
    "فیلم",
    "بەڵگەنامە",
    "کوردستان"
  ],
  "tagsKmr": [
    "fîlm",
    "belgefîlm",
    "Kurdistan"
  ],
  "keywordsCkb": [
    "فیلمی پێکەوەژیان",
    "کەلەپووری کورد"
  ],
  "keywordsKmr": [
    "Fîlmê Pêkvejiyan",
    "kelepûra Kurdî"
  ]
}
--KHI_CREATE_PUB_FILM_02--

> {%
  client.assert(response.status === 201, "create_pub_film_02 create failed");
  client.global.set("pub_film_02_id", response.body.id);
%}

