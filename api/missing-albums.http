### Album 02 — عەلی مەردان — upload preflight
# @name preflight_pub_album_02
GET {{baseUrl}}/api/v1/sound-tracks?page=0&size=1
Authorization: Bearer {{auth_token}}

> {%
  const required = [];
  for (let i = 1; i <= 13; i++) required.push("pub_album_02_image_" + String(i).padStart(2, "0"));
  for (let i = 1; i <= 65; i++) required.push("pub_album_02_track_" + String(i).padStart(3, "0"));
  const missing = required.filter(name => !client.global.get(name));
  client.assert(response.status === 200, "Album 02 preflight failed: HTTP " + response.status);
  client.assert(missing.length === 0, "Album 02 missing uploads: " + missing.join(", "));
%}

### Album 02 — عەلی مەردان — create
# @name create_pub_album_02
