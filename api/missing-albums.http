> {%
  client.assert(response.status === 201, "create_pub_album_02 create failed");
  client.global.set("pub_album_02_id", response.body.data.id);
%}

### Album 02 — عەلی مەردان — verify
# @name verify_create_pub_album_02
GET {{baseUrl}}/api/v1/sound-tracks/{{pub_album_02_id}}
Authorization: Bearer {{auth_token}}

> {%
  client.assert(response.status === 200, "create_pub_album_02 verification failed");
  client.assert(response.body.data.trackState === "MULTI", "Album 02 state mismatch");
  client.assert(response.body.data.files.length === 65, "Album 02 track count mismatch");
%}

