### Album 07 — مریەم خان — upload preflight
# @name preflight_pub_album_07
GET {{baseUrl}}/api/v1/sound-tracks?page=0&size=1
Authorization: Bearer {{auth_token}}

> {%
  const required = [];
  for (let i = 1; i <= 4; i++) required.push("pub_album_07_image_" + String(i).padStart(2, "0"));
  for (let i = 1; i <= 21; i++) required.push("pub_album_07_track_" + String(i).padStart(3, "0"));
  const missing = required.filter(name => !client.global.get(name));
  client.assert(response.status === 200, "Album 07 preflight failed: HTTP " + response.status);
  client.assert(missing.length === 0, "Album 07 missing uploads: " + missing.join(", "));
%}

### Album 07 — مریەم خان — create
# @name create_pub_album_07
POST {{baseUrl}}/api/v1/sound-tracks
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_ALBUM_07

--KHI_CREATE_PUB_ALBUM_07
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "soundType": "گۆرانیی کوردی",
  "trackState": "MULTI",
  "albumOfMemories": false,
  "ckbCoverUrl": "{{pub_album_07_image_03}}",
  "kmrCoverUrl": "{{pub_album_07_image_03}}",
  "hoverCoverUrl": "{{pub_album_07_image_04}}",
  "newTopic": {
    "nameCkb": "گۆرانیی کوردی",
    "nameKmr": "Stranên Kurdî"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "مریەم خان",
    "description": "ژنە گۆرانیبێژی کورد (مریەم خان) ناوی تەواوی (مریەم محەمەد ئەحمەد)ە و لە ساڵی ١٩٠٤، لە گوندی (دێرگول)ی سەر بە ناوچەی جزیرەی بۆتان لە دایک بووە.\nکاتێک کۆمپانیای تۆماری دەنگ لەسەر قەوان لە شاری (بەغدا) دادەمەزرێت، مریەم خانی هونەرمەند، بە هیوای ئەوەی کە گۆرانییەکانی لەسەر قەوان تۆمار بکات، ڕوو لە پایتەخت دەکات و لە ساڵی ١٩٣٠دا، چەند لاوک و بەستەیەکی لە لایەن کۆمپانیای (بەیزافۆن، ئۆدیۆن و ئەبولکەلب)ەوە، لەسەر قەوان بۆ تۆمار دەکرێت. لەوانە (لۆرکێ لۆرکێ، گولێ وەی نار، هەی بەردە بەردە، لێلێ وەسۆ، گوڵ شێنێ شێنێ، یار حەلیمێ، محەممەدۆ ڕۆنی، لێلێ ئێمێ، لێ دایێ، لۆلۆ سوارۆ، ئەی دەلال و زەمبیل فرۆش). بەم کارەشی، دەبێتە یەکەم گۆرانیبێژی کورد کە بە دیالێکتی کرمانجی ژووروو گۆرانی لەسەر قەوەوان تۆمار بکات.\nمریەم خان لە ساڵی ١٩٤٩دا، تووشی نەخۆشی گورچیلە دەبێت و لە مانگی تەمووزی هەمان ساڵدا، لە نەخۆشخانەی میر ئەلیاس لە بەغدا کۆچی دوایی دەکات و لە گۆڕستانی شێخ مارف بە خاک دەسپێردرێت."
  },
  "kmrContent": {
    "title": "Miryem Xan",
    "description": "Meryemxan, keça Mihemedê kurê Ehmedê Botan e. Ew, di sala 1904ê de li gundê Dêrgul ji dayik bûye ku ser bi Cizîra Botan e.\nDema kompaniya qewanan li Bexdayê tê damezrandin, Meryemxan bi hêviya ku stranên xwe li ser qewanê tomar bike, berê xwe dide Bexdayê û di sala 1930î de, çend lawik û besteyekê ji aliyê kompaniya Beyzafon, Audion û Ebulkelb ve li ser qewanan tomar dike; wekî Lorkê Lorkê, Gulê Wey Nar Wey Narê, Hey Berde Berde, Lê Lê Weso, Gulşênî Şênî, Yar Helîmê, Mihemedo Ronî, Lê Lê Emê, Lê Dayê, Lo Lo Siwaro, Ey Delal û Zembîlfiroş. Bi vî awayî ew dibe jina Kurd a pêşîn, ku bi şêwezarê Kurmanciya Jorîn li ser qewanê stranên xwe tomar dike.\nMeryemxan li sala 1949 an de, bi nexweşiya Gurçikan nexweş dikeve û di heyva tîrmeha heman sale de, li nexweşxana Mîr İlyas ya li Bexdayê, çûye ber dilovaniya Xwedê û li goristana Şêx Marif tê veşartin."
  },
