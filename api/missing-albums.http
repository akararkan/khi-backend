### Album 08 — ڕەشۆڵ — upload preflight
# @name preflight_pub_album_08
GET {{baseUrl}}/api/v1/sound-tracks?page=0&size=1
Authorization: Bearer {{auth_token}}

> {%
  const required = [];
  for (let i = 1; i <= 7; i++) required.push("pub_album_08_image_" + String(i).padStart(2, "0"));
  for (let i = 1; i <= 11; i++) required.push("pub_album_08_track_" + String(i).padStart(3, "0"));
  const missing = required.filter(name => !client.global.get(name));
  client.assert(response.status === 200, "Album 08 preflight failed: HTTP " + response.status);
  client.assert(missing.length === 0, "Album 08 missing uploads: " + missing.join(", "));
%}

### Album 08 — ڕەشۆڵ — create
# @name create_pub_album_08
POST {{baseUrl}}/api/v1/sound-tracks
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_ALBUM_08

--KHI_CREATE_PUB_ALBUM_08
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "soundType": "گۆرانیی کوردی",
  "trackState": "MULTI",
  "albumOfMemories": false,
  "ckbCoverUrl": "{{pub_album_08_image_04}}",
  "kmrCoverUrl": "{{pub_album_08_image_04}}",
  "hoverCoverUrl": "{{pub_album_08_image_07}}",
  "newTopic": {
    "nameCkb": "گۆرانیی کوردی",
    "nameKmr": "Stranên Kurdî"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "ڕەشۆڵ",
    "description": "ڕەشید حاجی عەبدوڵڵا میرزا عەزیز ناسراو بە ڕەشۆڵ، دەوروبەری ساڵی ١٩١٢ لە گەڕەكی سەرشەقامی شاری سلێمانی لەدایك بووە.\nڕەشۆڵ سەرەتای ساڵانی سییەكانی سەدەی ڕابوردوو، وەك دەنگخۆش دەركەوتووە و بە هەوڵی عومەر قەزازی بریكاری قەوان لە سلێمانی، لەگەڵ مەلا كەریمی گۆرانیبێژدا، بۆ شاری بەغدا چوون و چەند گۆرانییەكی لەسەر قەوان تۆماركردووە، وەك: كەوای بەرت ماهووتە، خاسێ تۆ خانمی و سروودی دڵ لە دەردی وەتەن. ڕەشۆڵ لەگەڵ \"مەحموودی حەمەی لەیلێ\"دا، ساڵی ١٩٤٩ لە بەشی كوردیی ڕادیۆی بەغدادا، چەند گۆرانییەكی تری تۆماركردووە، وەك: گیان ئازیزەكەم، ئامینێ نازەنینێ و دەستم لێ مەدەن. ڕادیۆ بەغدا ڕۆژی ٤/٧/١٩٤٩ یەكەم بەرهەمی ڕەشۆڵی بڵاوكردووەتەوە.\nڕەشۆڵ وەك زۆربەی هونەرمەندان، لە شۆڕشی ساڵی ١٩٧٤دا بەشداری كردووە و هەر لەو ساڵەشدا نەخۆش كەوتووە، ڕۆژی ١٤/٧/١٩٧٤ لە شاری تاران كۆچی دوایی كردووە و لە دەربەندی ڕایات - حاجی ئۆمەران بەخاك سپێردراوە."
  },
  "kmrContent": {
    "title": "Reşol",
    "description": "Reşîd hacî Ebdella Mîrza Ezîz bi navê Reşol hatiye nas kirin, derdora sala 1912'an li taxa Serşeqam li bajarê Silêmaniyê ji dayik bûye.\nReşol, di destpêka salên sihî de, wek dengxweşekî hatiye nas kirin û bi riya Umer Qezaz ê birêkarê qewanan li Silêmaniyê û bi mela Kerîm ê dengbêj re çûne Bexdê û çend stiran li ser qewanan tomar kiriye, wek: Keway Berit Mahût e, Xasî To Xanimî û Sirûdî Dil Le Derdî Weten. Reşol, bi ''Mehmûdê Hemey Leylê'' re, di sala 1949ê de, li beşa Kurdî ya radyoya Bexdê de, çend stiranên din tomar kiriye, wek: Giyan Azîzekem, Amînê Nazenînê û Destim Lê Meden. Radyoya Bexda, di roja 7/4/1949ê de yekem berhema Reşol belav kiriye.\nReşol, wek piraniya hunermendan, di şoreşa sala 1974'ê de beşdarî kiriye û her di wê salê de jî nexweş ketiye, di roja 14/7/1974'ê de li bajarê Tehranê koça dawî kiriye û li derbenda Raye- Hacî Omeran, termê wî hatiye sipartin."
  },
  "locations": [
    "کوردستان"
  ],
