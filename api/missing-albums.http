### Album 03 — تاهیر تۆفیق — upload preflight
# @name preflight_pub_album_03
GET {{baseUrl}}/api/v1/sound-tracks?page=0&size=1
Authorization: Bearer {{auth_token}}

> {%
  const required = [];
  for (let i = 1; i <= 15; i++) required.push("pub_album_03_image_" + String(i).padStart(2, "0"));
  for (let i = 1; i <= 73; i++) required.push("pub_album_03_track_" + String(i).padStart(3, "0"));
  const missing = required.filter(name => !client.global.get(name));
  client.assert(response.status === 200, "Album 03 preflight failed: HTTP " + response.status);
  client.assert(missing.length === 0, "Album 03 missing uploads: " + missing.join(", "));
%}

### Album 03 — تاهیر تۆفیق — create
# @name create_pub_album_03
POST {{baseUrl}}/api/v1/sound-tracks
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_PUB_ALBUM_03

--KHI_CREATE_PUB_ALBUM_03
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "soundType": "گۆرانیی کوردی",
  "trackState": "MULTI",
  "albumOfMemories": false,
  "ckbCoverUrl": "{{pub_album_03_image_05}}",
  "kmrCoverUrl": "{{pub_album_03_image_05}}",
  "hoverCoverUrl": "{{pub_album_03_image_06}}",
  "newTopic": {
    "nameCkb": "گۆرانیی کوردی",
    "nameKmr": "Stranên Kurdî"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "تاهیر تۆفیق",
    "description": "ناوی تاهیر تۆفیق ئەوڕەحمان حەمەد شێخانییە. بە گوتەی خۆی لە ساڵی (١٩٢٢) ''ساڵی تەیاران\"لە گەڕەکی بەفری قەندی شاری کۆیە\" لەدایک بووە.\nهونەرمەند تایەر تۆفیق لە زۆربەی شارەکانی کوردستاندا ئاهەنگی گۆرانی سازکردووە و چەندین جاریش بە سەردان بۆ شاری کۆیە گەڕاوەتەوە و لەگەڵ چەند تیپێکی مۆسیقادا \"باواجی و مەولەوی\"، بە بەشداری هونەرمەندانی وەک: قادر دیلان و نەجاتی عەبدە و ویلیەم یۆحەننا، ئاهەنگیان گێڕاوە.\nجگە لەمانەش، کۆمەڵێک کتێبی لەسەر گۆرانی کوردی بەگشتی و گۆرانییەکانی خۆی بەتایبەتی بە چاپ گەیاندوون، وەک: چەپکە گوڵ، ئاوازی بەسۆز، گۆرانی و هەڵپەڕکێ، گۆرانی و ژیان و گوڵی سەربەستی.\nمامۆستا تاهیر بەهۆی توشبوونی بە نەخۆشیەکی سەخت لە ٢٠ی تشرینی یەکەمی ساڵی ١٩٨٧دا وەک جەستە ماڵئاوایی دەکات و لە زێدی خۆی بەخاک دەسپێردرێت."
  },
  "kmrContent": {
    "title": "Tahir Tofîq",
    "description": "Navê wî Tahir Tofîq Ewrehman Hemed Şêxanî ye, di sala 1922’an de li taxa Befrî Qendyî li bajarê Koyê ji dayîk bûye\nHunermend Tahir Tofîq li gelek bajarên Kurdistanê konsert û aheng vegirtine û çendîn car vegeriyaye Koyê û ligel çend komên mûzîkê yên wek ‘’Bawacî’’ û ‘’Mewlewî’’ bi beşdariya hunermendên wek; Qadir Dîlan, Najatî Ebda û Wîlyem Yohanna aheng pêşkêş kirine.\nHerweha wî çend pirtûk li ser stiranên kurdî bi giştî û stranên xwe bi taybetî çap kirine, wek: Çepkegul, Awazî Besoz, Goranî û Helparkê, Goranî û Jiyan û Gulî Serbestî. Tahir Tofîq di 20'ê Cotmeha sala 1987'an de ji ber nexweşiyeke giran jiyana xwe ji dest da û li bajarê xwe hate veşartin."
  },
  "locations": [
    "کوردستان"
  ],
  "reader": "تاهیر تۆفیق",
  "directors": [],
  "terms": "ئەرشیفی دەنگ",
  "thisProjectOfInstitute": true,
