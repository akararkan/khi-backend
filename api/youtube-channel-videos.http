### KHI YouTube video import — real Kurdish Heritage Institute channel data
### Source: https://www.youtube.com/@KurdishHeritageInstitute/videos
### Generated records: 98 VIDEO_CLIP records, one embedded YouTube video per record.
### Run Login, then run each Create + Verify pair from top to bottom.
### No local video upload is required. Covers use YouTube thumbnail URLs.
### Do not rerun a successful Create request; the API does not deduplicate YouTube IDs.

@baseUrl = https://blissful-spontaneity-production.up.railway.app
@username = akar
@password = 11111111

### Login
# @name login_youtube_videos
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
  client.assert(response.status === 200, "YouTube import login failed: HTTP " + response.status + " " + JSON.stringify(response.body));
  client.global.set("auth_token", response.body.token);
%}

###############################################################################
# YOUTUBE VIDEOS — 98 RECORDS
###############################################################################

###############################################################################
# VIDEO 001 — فەرهەنگی گۆران
# YouTube: https://www.youtube.com/watch?v=u82TtbXpTvw
# Duration: 1:10 (70 seconds)
###############################################################################

### Create YouTube video 001
# @name create_youtube_video_001
POST {{baseUrl}}/api/v1/videos
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=KHI_CREATE_YOUTUBE_VIDEO_001

--KHI_CREATE_YOUTUBE_VIDEO_001
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "ckbCoverUrl": "https://i.ytimg.com/vi/u82TtbXpTvw/hqdefault.jpg",
  "kmrCoverUrl": "https://i.ytimg.com/vi/u82TtbXpTvw/hqdefault.jpg",
  "hoverCoverUrl": "https://i.ytimg.com/vi/u82TtbXpTvw/hqdefault.jpg",
  "videoType": "VIDEO_CLIP",
  "albumOfMemories": false,
  "newTopic": {
    "nameCkb": "ڤیدیۆکانی یوتیوب",
    "nameKmr": "Vîdeoyên YouTube"
  },
  "contentLanguages": [
    "CKB",
    "KMR"
  ],
  "ckbContent": {
    "title": "فەرهەنگی گۆران",
    "description": "<p>ڤیدیۆی کەناڵی یوتیوبی ئینستیتیوتی کەلەپووری کورد.</p>",
    "producer": "ئینستیتیوتی کەلەپووری کورد"
  },
  "kmrContent": {
    "title": "فەرهەنگی گۆران",
    "description": "<p>Vîdeoya kanala YouTube ya Enstîtuya Kelepûra Kurdî.</p>",
    "producer": "Enstîtuya Kelepûra Kurdî"
  },
  "videoClipItems": [
    {
      "externalUrl": "https://www.youtube.com/watch?v=u82TtbXpTvw",
      "embedUrl": "https://www.youtube.com/embed/u82TtbXpTvw",
      "clipNumber": 1,
      "durationSeconds": 70,
      "fileFormat": "youtube",
      "titleCkb": "فەرهەنگی گۆران",
      "titleKmr": "فەرهەنگی گۆران",
      "descriptionCkb": "لە کەناڵی Kurdish Heritage Institute لە یوتیوب.",
      "descriptionKmr": "Ji kanala YouTube ya Kurdish Heritage Institute."
    }
  ],
  "fileFormat": "youtube",
  "durationSeconds": 70,
  "tagsCkb": [
    "ڤیدیۆ",
    "یوتیوب",
    "کەلەپووری کوردی"
  ],
  "tagsKmr": [
    "vîdeo",
    "YouTube",
    "kelepûra Kurdî"
  ],
  "keywordsCkb": [
    "فەرهەنگی گۆران",
    "Kurdish Heritage Institute"
  ],
  "keywordsKmr": [
    "فەرهەنگی گۆران",
    "Kurdish Heritage Institute"
  ]
}
--KHI_CREATE_YOUTUBE_VIDEO_001--

> {%
  client.assert(response.status === 201, "create_youtube_video_001 failed: HTTP " + response.status + " " + JSON.stringify(response.body));
  client.assert(response.body.videoType === "VIDEO_CLIP", "YouTube video 001 type mismatch");
  client.assert(response.body.videoClipItems && response.body.videoClipItems.length === 1, "YouTube video 001 clip missing");
  client.assert(response.body.videoClipItems[0].embedUrl === "https://www.youtube.com/embed/u82TtbXpTvw", "YouTube video 001 embed URL mismatch");
  client.global.set("youtube_video_001_id", response.body.id);
  client.assert(response.body.topicId != null, "YouTube topic was not created");
  client.global.set("youtube_video_topic_id", response.body.topicId);
%}

### Verify YouTube video 001
# @name verify_youtube_video_001
GET {{baseUrl}}/api/v1/videos/{{youtube_video_001_id}}
Authorization: Bearer {{auth_token}}

> {%
  client.assert(response.status === 200, "verify_youtube_video_001 failed: HTTP " + response.status + " " + JSON.stringify(response.body));
  client.assert(response.body.videoType === "VIDEO_CLIP", "YouTube video 001 verification type mismatch");
  client.assert(response.body.videoClipItems && response.body.videoClipItems[0].embedUrl === "https://www.youtube.com/embed/u82TtbXpTvw", "YouTube video 001 verification embed mismatch");
%}

